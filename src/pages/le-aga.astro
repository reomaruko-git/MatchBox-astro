---
/**
 * le-aga.astro
 * レバクリ AGA治療 LP（専用ページ）
 * LayoutLp.astro + lp-template.css を使用
 */
import LayoutLp from '../layouts/LayoutLp.astro';
import mvImage from '../assets/images/lp/le-aga/mv.webp';

const affiliateUrl = "/link/le-aga/";
---

<LayoutLp
  title="深夜0時、スマホで始めるAGA治療。月1,349円〜。初診料0円。｜レバクリ"
  description="プライバシーに配慮して、今夜から。最短翌日お届け。スマホで予約から処方まで完結。初診料・再診料0円、いつでも解約可能。レバクリのオンラインAGA治療。"
  affiliateUrl={affiliateUrl}
  canonical="https://matchbox-media.com/le-aga/"
  ogImage={mvImage.src}
  colors={{ primary: "#1A2744", accent: "#00B4A0", accentDark: "#009688" }}
>

<!-- ============================================================
     HERO
============================================================ -->
<section class="hero">
  <span class="pr-badge">PR</span>
  <img class="hero-photo" src={mvImage.src} alt="AGA治療のイメージ" />
  <div class="hero-overlay"></div>
  <div class="hero-inner">
    <p class="hero-kicker">＼今夜から始められる／</p>
    <h1 class="hero-title">
      通院不要<span class="punc">、</span>診察<span class="particle">は</span><br />最短15分<span class="punc">。</span><br />
      <span class="accent">スマホ<span class="particle">で</span>完結<span class="particle">する</span><span class="punc">、<br /></span>現代<span class="particle">の</span>AGA治療。</span>
    </h1>
    <p class="hero-sub">継続しやすい定額プラン 1,349円〜 | 26時まで診察対応</p>
    <div class="hero-badges">
      <span class="hero-badge">
        <svg class="badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 2H5a1 1 0 00-1 1v4l6 6 5-5-6-6z"/>
          <circle cx="6.5" cy="5.5" r="1" fill="currentColor" stroke="none"/>
        </svg>
        初診料・再診料 0円
      </span>
      <span class="hero-badge">
        <svg class="badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2L3 4.5V8c0 2.8 2 4.8 5 5.5 3-.7 5-2.7 5-5.5V4.5L8 2z"/>
          <path d="M5.5 8l2 2 3-3"/>
        </svg>
        いつでも解約可能
      </span>
      <span class="hero-badge">
        <svg class="badge-icon" viewBox="0 0 16 16" fill="currentColor" stroke="none">
          <path d="M9.8 1.5 5 9h3.5L6.2 14.5 13 7H9.5l.3-5.5z"/>
        </svg>
        最短即日発送・翌日届く
      </span>
      <span class="hero-badge sp-only">
        <svg class="badge-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="7" width="10" height="7" rx="1.5"/>
          <path d="M5 7V5a3 3 0 016 0v2"/>
        </svg>
        2年目以降も同価格
      </span>
    </div>
    <div class="hero-cta-wrap">
      <a href={affiliateUrl} class="btn-primary">
        今すぐ無料で診察を予約する
        <i class="arrow">›</i>
      </a>
      <span class="hero-microcopy">※24時間予約OK／診察は約15分／スマホで完結</span>
    </div>
  </div>
</section>


<!-- ============================================================
     感情訴求
============================================================ -->
<section class="lp-section bg-white">
  <div class="lp-inner">
    <h2 class="hdg-h2-border">ふとした瞬間に、あれ？って思うことありますよね。</h2>
    <div class="illust-split">
      <div class="illust-text">
        <div class="lp-prose">
          <p>風呂上がり、濡れた髪をかき上げたとき。指の間に絡まる抜け毛を、つい数えてしまう。</p>
          <p>蛍光灯の下で、<span class="marker">頭頂部の地肌が透けて見えた</span>あの瞬間。胸がざわつくような、あの嫌な感覚。</p>
          <p>集合写真を見返して、自分の頭だけが光を反射していることに気づく。</p>
        </div>
      </div>
      <div class="illust-fig">
        <!-- SVG①：悩む男性 -->
        <svg viewBox="0 0 240 210" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="105" cy="115" r="90" fill="#EEF3FA"/>
          <path d="M72 148 L72 200 L138 200 L138 148 Q128 133 110 129 L105 133 L100 129 Q82 133 72 148Z" fill="#1A2744"/>
          <rect x="98" y="118" width="14" height="18" rx="3" fill="#F5C9A0"/>
          <ellipse cx="105" cy="97" rx="25" ry="27" fill="#F5C9A0"/>
          <path d="M84 85 Q94 73 105 71 Q116 69 126 85" stroke="#7A5C1E" stroke-width="2.5" fill="none" stroke-linecap="round"/>
          <line x1="91" y1="82" x2="89" y2="74" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="99" y1="77" x2="98" y2="69" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="111" y1="76" x2="112" y2="68" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="120" y1="80" x2="122" y2="72" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M92 89 L99 87" stroke="#7A5C1E" stroke-width="2" stroke-linecap="round"/>
          <path d="M111 87 L118 89" stroke="#7A5C1E" stroke-width="2" stroke-linecap="round"/>
          <circle cx="96" cy="95" r="3.5" fill="#2D1B0E"/>
          <circle cx="114" cy="95" r="3.5" fill="#2D1B0E"/>
          <path d="M98 108 Q105 104 112 108" stroke="#7A5C1E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M76 153 Q60 137 62 118" stroke="#1A2744" stroke-width="13" fill="none" stroke-linecap="round"/>
          <circle cx="62" cy="113" r="9" fill="#F5C9A0"/>
          <path d="M134 153 Q148 165 148 180" stroke="#1A2744" stroke-width="13" fill="none" stroke-linecap="round"/>
          <circle cx="148" cy="184" r="9" fill="#F5C9A0"/>
          <circle cx="150" cy="88" r="3" fill="#C8D8F0"/>
          <circle cx="162" cy="76" r="5" fill="#C8D8F0"/>
          <circle cx="178" cy="60" r="16" fill="white" stroke="#D0DFF0" stroke-width="1.5"/>
          <circle cx="193" cy="60" r="13" fill="white" stroke="#D0DFF0" stroke-width="1.5"/>
          <circle cx="185" cy="48" r="13" fill="white" stroke="#D0DFF0" stroke-width="1.5"/>
        </svg>
      </div>
    </div>

    <p style="font-size:14px;font-weight:700;color:var(--text-sub);margin-top:32px;margin-bottom:14px;">こんな経験はありませんか？</p>
    <div class="pain-cards">
      <div class="pain-card">
        <div class="pain-num">1</div>
        <div class="pain-text">「最近、ちょっと薄くなった？」の一言が一日中頭から離れない</div>
      </div>
      <div class="pain-card">
        <div class="pain-num">2</div>
        <div class="pain-text">育毛シャンプーやサプリを試したが、正直何も変わらなかった</div>
      </div>
      <div class="pain-card">
        <div class="pain-num">3</div>
        <div class="pain-text">クリニックに行けばいいのはわかってる。でも待合室で人に会いたくない</div>
      </div>
      <div class="pain-card">
        <div class="pain-num">4</div>
        <div class="pain-text">受付で「薄毛の治療で…」と言うのが、どうしても恥ずかしい</div>
      </div>
    </div>

    <div class="lp-prose" style="margin-top:24px;">
      <p>その気持ち、おかしくありません。<strong>多くの人が、まったく同じところで立ち止まっています。</strong></p>
    </div>
  </div>
</section>


<!-- ============================================================
     なぜ先延ばしが危険か
============================================================ -->
<section class="lp-section bg-gray">
  <div class="lp-inner">
    <h2 class="hdg-h2-border">「いつかやろう」が一番危険な理由</h2>
    <div class="lp-prose">
      <p>あなたと同じ悩みを抱えている20〜40代の男性は、想像以上に多くいます。そして、その多くが<strong>「まだ大丈夫だろう」と放置している</strong>のが現実です。</p>
    </div>

    <div class="callout">
      <div class="callout-icon">i</div>
      <div>
        <div class="callout-title">AGAは「進行性」の脱毛症です</div>
        <div class="callout-body">放置しても自然に止まることはなく、時間が経つほど毛根は弱り、減っていきます。一度失われた毛根は、自然には戻りません。</div>
      </div>
    </div>

    <!-- SVG②：AGA進行3段階 -->
    <div class="illust-center">
      <svg viewBox="0 0 300 165" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="50" cy="82" r="30" fill="#F5C9A0"/>
        <path d="M22 74 Q30 54 50 50 Q70 46 78 74" fill="#7A5C1E"/>
        <path d="M26 72 Q32 60 40 58" stroke="#5A3E10" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path d="M46 52 Q52 49 58 52" stroke="#5A3E10" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <circle cx="42" cy="84" r="2.5" fill="#2D1B0E"/>
        <circle cx="58" cy="84" r="2.5" fill="#2D1B0E"/>
        <path d="M43 94 Q50 99 57 94" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <rect x="26" y="119" width="48" height="20" rx="10" fill="#00B4A0"/>
        <text x="50" y="133" font-size="11" fill="white" text-anchor="middle" font-weight="700" font-family="Arial,sans-serif">今</text>
        <path d="M88 80 L108 80" stroke="#D1D5DB" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M104 74 L112 80 L104 86" fill="none" stroke="#D1D5DB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="150" cy="82" r="30" fill="#F5C9A0"/>
        <path d="M122 78 Q125 64 133 58 Q139 55 142 61 Q138 68 130 74Z" fill="#7A5C1E"/>
        <path d="M178 78 Q175 64 167 58 Q161 55 158 61 Q162 68 170 74Z" fill="#7A5C1E"/>
        <path d="M142 61 Q150 56 158 61" stroke="#7A5C1E" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <line x1="146" y1="59" x2="145" y2="52" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="151" y1="57" x2="151" y2="50" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="156" y1="59" x2="157" y2="52" stroke="#7A5C1E" stroke-width="1.5" stroke-linecap="round"/>
        <path d="M135 77 Q138 75 141 77" stroke="#7A5C1E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path d="M159 77 Q162 75 165 77" stroke="#7A5C1E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <circle cx="142" cy="84" r="2.5" fill="#2D1B0E"/>
        <circle cx="158" cy="84" r="2.5" fill="#2D1B0E"/>
        <path d="M144 94 Q150 91 156 94" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <rect x="118" y="119" width="64" height="20" rx="10" fill="#F97316"/>
        <text x="150" y="133" font-size="11" fill="white" text-anchor="middle" font-weight="700" font-family="Arial,sans-serif">半年後</text>
        <path d="M188 80 L208 80" stroke="#D1D5DB" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M204 74 L212 80 L204 86" fill="none" stroke="#D1D5DB" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="250" cy="82" r="30" fill="#F5C9A0"/>
        <line x1="241" y1="55" x2="240" y2="47" stroke="#7A5C1E" stroke-width="2" stroke-linecap="round"/>
        <line x1="250" y1="53" x2="250" y2="45" stroke="#7A5C1E" stroke-width="2" stroke-linecap="round"/>
        <line x1="259" y1="55" x2="260" y2="47" stroke="#7A5C1E" stroke-width="2" stroke-linecap="round"/>
        <path d="M237 77 Q240 75 243 77" stroke="#7A5C1E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <path d="M257 77 Q260 75 263 77" stroke="#7A5C1E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <circle cx="242" cy="84" r="2.5" fill="#2D1B0E"/>
        <circle cx="258" cy="84" r="2.5" fill="#2D1B0E"/>
        <path d="M244 97 Q250 93 256 97" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
        <rect x="220" y="119" width="60" height="20" rx="10" fill="#EF4444"/>
        <text x="250" y="133" font-size="11" fill="white" text-anchor="middle" font-weight="700" font-family="Arial,sans-serif">1年後</text>
        <text x="150" y="157" font-size="10" fill="#9CA3AF" text-anchor="middle" font-family="Arial,sans-serif">放置するほど、取り戻せる髪が減っていく</text>
      </svg>
    </div>

    <h3 class="hdg-h3-dot">育毛シャンプーやサプリとは、アプローチが異なります</h3>
    <div class="lp-prose">
      <p>AGAの原因は、男性ホルモン（テストステロン）から生まれる<strong>DHT（ジヒドロテストステロン）</strong>という物質です。このDHTが毛根に作用して、髪の成長サイクルを短縮させていきます。</p>
      <p>育毛シャンプーやサプリは頭皮環境を整えることを目的としたものが多く、AGAの進行原因であるDHTへの対処とはアプローチが異なります。<strong>医薬品によるAGA治療は、DHTを抑制する有効な選択肢の一つ</strong>として知られています。</p>
    </div>

    <h3 class="hdg-h3-dot" style="margin-top:32px;">まだ諦めるには早い！</h3>
    <div class="lp-prose">
      <p><span class="marker-teal">治療を早く始めた人ほど、効果を実感しやすい。</span>これは医学的にも広く認められている事実です。</p>
      <p>つまり、「いつかやろう」と先延ばしするほど、取り戻せる髪は少なくなっていく。だからこそ、<strong>「今夜、自宅から、誰にも会わずに」始められる方法</strong>が必要なんです。</p>
    </div>
    <div class="text-cta-wrap">
      <a href={affiliateUrl} class="text-cta">今すぐ、スマホで無料診察を予約する →</a>
    </div>
  </div>
</section>


<!-- ============================================================
     サービス説明・特徴
============================================================ -->
<section class="lp-section bg-white">
  <div class="lp-inner">
    <h2 class="hdg-h2-border">自宅がクリニックになる。レバクリのオンラインAGA治療。</h2>
    <div class="illust-split illust-rev">
      <div class="illust-text">
        <div class="lp-prose">
          <p>「クリニックに行く時間がない」「待合室で人に会いたくない」「続けやすい価格じゃないと厳しい」...<br>その悩みに応えるために作られたのが、<strong><a href={affiliateUrl} class="inline-link">オンラインAGA治療のレバクリ</a></strong>です。</p>
        </div>
      </div>
      <div class="illust-fig">
        <!-- SVG③：スマホで自宅診察 -->
        <svg viewBox="0 0 240 200" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="115" cy="105" r="88" fill="#EEF3FA"/>
          <rect x="28" y="152" width="186" height="34" rx="12" fill="#1A2744" opacity="0.10"/>
          <rect x="28" y="152" width="42" height="34" rx="10" fill="#1A2744" opacity="0.12"/>
          <rect x="172" y="152" width="42" height="34" rx="10" fill="#1A2744" opacity="0.12"/>
          <path d="M82 118 L82 172 L148 172 L148 118 Q138 105 120 101 L115 105 L110 101 Q92 105 82 118Z" fill="#00B4A0"/>
          <path d="M84 165 L70 188" stroke="#00B4A0" stroke-width="15" stroke-linecap="round" fill="none"/>
          <path d="M146 165 L160 188" stroke="#00B4A0" stroke-width="15" stroke-linecap="round" fill="none"/>
          <rect x="108" y="91" width="14" height="18" rx="3" fill="#F5C9A0"/>
          <ellipse cx="115" cy="74" rx="24" ry="25" fill="#F5C9A0"/>
          <path d="M93 65 Q101 50 115 47 Q129 44 137 65" fill="#7A5C1E"/>
          <path d="M107 73 Q110 70 113 73" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M117 73 Q120 70 123 73" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M109 83 Q115 89 121 83" stroke="#2D1B0E" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M84 124 Q72 140 66 158" stroke="#00B4A0" stroke-width="14" fill="none" stroke-linecap="round"/>
          <ellipse cx="64" cy="162" rx="9" ry="8" fill="#F5C9A0"/>
          <path d="M146 121 Q164 117 170 112" stroke="#00B4A0" stroke-width="14" fill="none" stroke-linecap="round"/>
          <ellipse cx="169" cy="117" rx="9" ry="8" fill="#F5C9A0"/>
          <rect x="164" y="100" width="32" height="50" rx="5" fill="#1A2744"/>
          <rect x="167" y="104" width="26" height="42" rx="3" fill="white"/>
          <circle cx="180" cy="118" r="10" fill="#E0F4F2"/>
          <circle cx="177" cy="116" r="2" fill="#2D1B0E"/>
          <circle cx="183" cy="116" r="2" fill="#2D1B0E"/>
          <path d="M177 123 Q180 126 183 123" stroke="#00B4A0" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <path d="M170 110 Q175 104 180 103 Q185 104 190 110" fill="#00B4A0"/>
          <line x1="180" y1="103" x2="180" y2="108" stroke="white" stroke-width="1.5"/>
          <line x1="177" y1="105.5" x2="183" y2="105.5" stroke="white" stroke-width="1.5"/>
          <rect x="167" y="134" width="26" height="8" rx="4" fill="#00B4A0" opacity="0.15"/>
          <text x="180" y="141" font-size="6" fill="#00B4A0" text-anchor="middle" font-weight="700" font-family="Arial,sans-serif">診察中</text>
        </svg>
      </div>
    </div>

    <h3 class="reason-heading">続けられる<br />3つの仕組み</h3>
    <div class="reason-cards">

      <div class="reason-card">
        <div class="reason-num">1</div>
        <div class="reason-icon-wrap">
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="14" y="4" width="20" height="34" rx="3" stroke="#00B4A0" stroke-width="2.2" fill="white"/>
            <rect x="17" y="8" width="14" height="20" rx="1.5" fill="#E6F7F6"/>
            <circle cx="24" cy="33" r="1.5" fill="#00B4A0"/>
            <circle cx="32" cy="14" r="7" fill="#E6F7F6" stroke="#00B4A0" stroke-width="1.8"/>
            <path d="M32 11v3.5l2 2" stroke="#00B4A0" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="reason-title">スマホ1つ<br />最短15分で処方完了</div>
        <div class="reason-desc">予約から診察・処方まですべてスマホで完結。アプリ不要、来院不要。深夜26時まで対応しているので、仕事終わりや寝る前でもOK。</div>
      </div>

      <div class="reason-card">
        <div class="reason-num">2</div>
        <div class="reason-icon-wrap">
          <!-- コイン（円マーク） -->
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="24" cy="24" r="17" fill="#E6F7F6" stroke="#00B4A0" stroke-width="2.2"/>
            <circle cx="24" cy="24" r="11" fill="white" stroke="#00B4A0" stroke-width="1.6"/>
            <text x="24" y="29" text-anchor="middle" font-size="13" font-weight="700" fill="#00B4A0" font-family="sans-serif">¥</text>
          </svg>
        </div>
        <div class="reason-title">月1,349円〜<br />2年目以降も同じ価格</div>
        <div class="reason-desc">「初回だけ安くて2年目から値上がり」がありません。育毛プランは12ヶ月定期で月1,349円。送料込みプランもあり、続けやすい価格設定です。</div>
      </div>

      <div class="reason-card">
        <div class="reason-num">3</div>
        <div class="reason-icon-wrap">
          <!-- ダンボール箱 -->
          <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- 箱本体 -->
            <rect x="8" y="20" width="32" height="22" rx="2" fill="#E6F7F6" stroke="#00B4A0" stroke-width="2.2"/>
            <!-- フタ左 -->
            <path d="M8 20 L16 13 L32 13 L40 20" stroke="#00B4A0" stroke-width="2.2" stroke-linejoin="round" fill="#E6F7F6"/>
            <!-- フタの折り目（中央線） -->
            <path d="M24 13 L24 20" stroke="#00B4A0" stroke-width="2" stroke-linecap="round"/>
            <!-- 箱中央の帯（テープ） -->
            <path d="M24 20 L24 42" stroke="#00B4A0" stroke-width="2" stroke-linecap="round"/>
            <path d="M8 28 L40 28" stroke="#00B4A0" stroke-width="2" stroke-linecap="round"/>
